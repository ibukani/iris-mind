{
  "languages": {
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "language_servers": ["ruff"],
        "command": "ruff",
        "arguments": ["format", "--stdin-filename", "{buffer_path}"]
      }
    }
  },
  "language_servers": ["ruff", "pyright"],
  "code_actions_on_format": {
    "source.fixAll.ruff": true,
    "source.organizeImports.ruff": true
  }
}
