{
    "pythonVersion": "3.13",
    "typeCheckingMode": "basic",
    "include": ["iris"],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        "**/.*",
        "build",
        "dist",
        "venv", // ← これを追加（ドットなし）
        ".venv", // ← 念のためこれも追加
        "tests",
    ],
    "venvPath": ".",
    "venv": "venv", // ← ".venv" から "venv" に変更

    "reportMissingImports": false,
    "reportMissingTypeStubs": false,
}
